
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#05091a}
.wrap{position:relative;width:100%;height:200px;background:#05091a;overflow:hidden;font-family:system-ui,-apple-system,sans-serif;border-radius:12px}
canvas{position:absolute;top:0;left:0;width:100%;height:100%}
.overlay{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:0 2.5rem;z-index:10;pointer-events:none}
.tag{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(200,175,100,.6);margin-bottom:10px;font-weight:500}
.title{font-size:32px;font-weight:700;color:#e8d5a3;line-height:1.1;letter-spacing:-0.5px}
.title span{color:rgba(160,196,255,.85)}
.sub{margin-top:10px;font-size:12px;color:rgba(160,185,230,.55);letter-spacing:.08em;font-weight:400}
.pills{position:absolute;right:2.5rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:10px;z-index:10;pointer-events:none}
.pill{background:rgba(255,255,255,.04);border:1px solid rgba(200,170,80,.18);border-radius:30px;padding:7px 18px;display:flex;align-items:center;gap:8px}
.pill-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.pill-dot.gold{background:#c9a055}
.pill-dot.blue{background:#6a9fd8}
.pill-dot.red{background:#c06060}
.pill-text{font-size:11px;color:rgba(200,215,250,.7);letter-spacing:.05em;white-space:nowrap}
</style>

<div class="wrap" id="wrap">
  <canvas id="c"></canvas>
  <div class="overlay">
    <div class="tag">Part 1 · Shanghai property guide</div>
    <div class="title">What can you<br>actually <span>buy?</span></div>
    <div class="sub">New builds · Resale · The one rule that governs both</div>
  </div>
  <div class="pills">
    <div class="pill"><div class="pill-dot gold"></div><div class="pill-text">New development</div></div>
    <div class="pill"><div class="pill-dot blue"></div><div class="pill-text">Resale property</div></div>
    <div class="pill"><div class="pill-dot red"></div><div class="pill-text">1 property limit</div></div>
  </div>
</div>

<script>
(function(){
  const wrap = document.getElementById('wrap');
  const c = document.getElementById('c');
  const ctx = c.getContext('2d');
  let W, H, t = 0;
  let mouse = {x: -1, y: -1};

  function resize(){
    W = wrap.offsetWidth;
    H = wrap.offsetHeight;
    c.width = W;
    c.height = H;
  }

  function drawSky(){
    ctx.fillStyle = '#05091a';
    ctx.fillRect(0,0,W,H);
    for(let i=0;i<60;i++){
      const sx = (i*137.5)%W;
      const sy = (i*97.3+Math.sin(i)*40)%(H*0.65);
      const twinkle = 0.3+0.7*Math.abs(Math.sin(t*0.02+i*0.8));
      const r = 0.5+Math.random()*0.5;
      ctx.beginPath();
      ctx.arc(sx,sy,r,0,Math.PI*2);
      ctx.fillStyle=`rgba(200,220,255,${twinkle*0.6})`;
      ctx.fill();
    }
  }

  function drawBuildings(){
    const bldgs = [
      {x:0,   w:40,  h:95,  win:[[8,20],[8,35],[8,50],[8,65],[22,20],[22,35],[22,50],[22,65]]},
      {x:38,  w:28,  h:70,  win:[[6,15],[6,28],[6,41],[6,54],[16,15],[16,28],[16,41],[16,54]]},
      {x:64,  w:48,  h:110, win:[[6,18],[6,32],[6,46],[6,60],[6,74],[22,18],[22,32],[22,46],[22,60],[22,74],[36,18],[36,32],[36,46]]},
      {x:110, w:22,  h:60,  win:[[5,12],[5,24],[5,36],[5,48],[13,12],[13,24],[13,36]]},
      {x:130, w:55,  h:130, win:[[8,15],[8,30],[8,45],[8,60],[8,75],[8,90],[22,15],[22,30],[22,45],[22,60],[22,75],[22,90],[38,15],[38,30],[38,45],[38,60],[38,75]]},
      {x:183, w:18,  h:80,  win:[[4,12],[4,24],[4,36],[4,48],[4,60],[10,12],[10,24],[10,36],[10,48]]},
      {x:199, w:38,  h:150, peak:true, win:[[6,25],[6,40],[6,55],[6,70],[6,85],[6,100],[6,115],[20,25],[20,40],[20,55],[20,70],[20,85],[20,100],[20,115]]},
      {x:235, w:30,  h:90,  win:[[5,15],[5,28],[5,41],[5,54],[5,67],[16,15],[16,28],[16,41],[16,54],[16,67]]},
      {x:263, w:45,  h:120, win:[[7,18],[7,33],[7,48],[7,63],[7,78],[7,93],[22,18],[22,33],[22,48],[22,63],[22,78],[22,93],[35,18],[35,33],[35,48],[35,63]]},
      {x:306, w:25,  h:75,  win:[[5,14],[5,27],[5,40],[5,53],[5,66],[14,14],[14,27],[14,40],[14,53]]},
      {x:329, w:60,  h:160, peak:true, sphere:true, win:[[10,40],[10,55],[10,70],[10,85],[10,100],[10,115],[10,130],[30,40],[30,55],[30,70],[30,85],[30,100],[30,115],[30,130],[48,40],[48,55],[48,70],[48,85]]},
      {x:387, w:35,  h:100, win:[[6,18],[6,32],[6,46],[6,60],[6,74],[6,88],[18,18],[18,32],[18,46],[18,60],[18,74],[18,88],[28,18],[28,32],[28,46]]},
      {x:420, w:28,  h:72,  win:[[5,14],[5,27],[5,40],[5,53],[5,66],[16,14],[16,27],[16,40],[16,53]]},
      {x:446, w:50,  h:115, win:[[7,20],[7,35],[7,50],[7,65],[7,80],[7,95],[22,20],[22,35],[22,50],[22,65],[22,80],[22,95],[38,20],[38,35],[38,50],[38,65]]},
      {x:494, w:32,  h:88,  win:[[6,16],[6,30],[6,44],[6,58],[6,72],[18,16],[18,30],[18,44],[18,58],[18,72]]},
      {x:524, w:42,  h:105, win:[[6,18],[6,32],[6,46],[6,60],[6,74],[6,88],[20,18],[20,32],[20,46],[20,60],[20,74],[20,88],[33,18],[33,32],[33,46],[33,60]]},
      {x:564, w:26,  h:68,  win:[[5,13],[5,26],[5,39],[5,52],[14,13],[14,26],[14,39],[14,52]]},
      {x:588, w:55,  h:95,  win:[[7,16],[7,30],[7,44],[7,58],[7,72],[22,16],[22,30],[22,44],[22,58],[22,72],[40,16],[40,30],[40,44],[40,58]]},
      {x:641, w:39,  h:80,  win:[[6,15],[6,28],[6,41],[6,54],[6,67],[20,15],[20,28],[20,41],[20,54],[20,67]]},
      {x:678, w:50,  h:60,  win:[[6,12],[6,25],[6,38],[6,51],[20,12],[20,25],[20,38],[20,51]]},
    ];

    const base = H;

    bldgs.forEach(b => {
      const bx = b.x, by = base - b.h, bw = b.w, bh = b.h;
      ctx.fillStyle = '#0d1528';
      ctx.fillRect(bx, by, bw, bh);
      if(b.peak){
        ctx.beginPath();
        ctx.moveTo(bx, by);
        ctx.lineTo(bx+bw/2, by-18);
        ctx.lineTo(bx+bw, by);
        ctx.closePath();
        ctx.fillStyle='#0d1528';
        ctx.fill();
      }
      if(b.sphere){
        const cx2=bx+bw/2, cy1=by-18, cy2=by-36;
        ctx.beginPath();ctx.arc(cx2,cy1,12,0,Math.PI*2);
        ctx.fillStyle='#111f3a';ctx.fill();
        ctx.strokeStyle='#1a3060';ctx.lineWidth=0.5;ctx.stroke();
        ctx.beginPath();ctx.arc(cx2,cy2,9,0,Math.PI*2);
        ctx.fillStyle='#111f3a';ctx.fill();
        ctx.stroke();
        ctx.beginPath();ctx.moveTo(cx2,cy1-12);ctx.lineTo(cx2,cy2+9);
        ctx.strokeStyle='#1a3060';ctx.lineWidth=1;ctx.stroke();
      }
      ctx.strokeStyle='rgba(100,140,200,0.06)';ctx.lineWidth=0.5;
      ctx.strokeRect(bx,by,bw,bh);

      b.win.forEach((w,wi) => {
        const wx=bx+w[0], wy=by+w[1];
        const dist = mouse.x>0 ? Math.hypot(mouse.x-(wx+4),mouse.y-(wy+4)) : 999;
        const glow = dist < 60 ? Math.max(0,(60-dist)/60) : 0;
        const baseAlpha = 0.12+0.18*Math.abs(Math.sin(t*0.015+wi*0.9+b.x*0.01));
        const alpha = Math.min(0.95, baseAlpha + glow*0.7);
        const warm = glow > 0.3;
        ctx.fillStyle = warm
          ? `rgba(255,210,120,${alpha})`
          : Math.random()<0.05
            ? `rgba(160,200,255,${alpha})`
            : `rgba(200,220,255,${alpha*0.7})`;
        ctx.fillRect(wx, wy, 7, 5);
      });
    });

    ctx.fillStyle='rgba(200,160,60,0.12)';
    ctx.fillRect(0,H-2,W,2);
  }

  function drawReflection(){
    ctx.save();
    ctx.globalAlpha=0.07;
    ctx.scale(1,-1);
    ctx.drawImage(c,0,-H*2,W,H);
    ctx.restore();
  }

  function frame(){
    t++;
    drawSky();
    drawBuildings();
    requestAnimationFrame(frame);
  }

  wrap.addEventListener('mousemove',function(e){
    const r=wrap.getBoundingClientRect();
    mouse.x=e.clientX-r.left;
    mouse.y=e.clientY-r.top;
  });
  wrap.addEventListener('mouseleave',function(){mouse.x=-1;mouse.y=-1;});

  resize();
  frame();
})();
</script>
